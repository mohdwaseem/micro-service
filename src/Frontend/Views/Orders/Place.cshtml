@model Frontend.Models.ViewModels.PlaceOrderViewModel
@{
    ViewData["Title"] = "Place Order";
}

<h2 class="mb-4">Place an Order</h2>

<div asp-validation-summary="All" class="text-danger mb-3"></div>

<form asp-action="Place" method="post">
    <div class="card shadow-sm mb-4">
        <div class="card-header">Select Products</div>
        <div class="card-body">
            @for (int i = 0; i < Model.Lines.Count; i++)
            {
                <div class="row g-2 mb-3 align-items-end order-line">
                    <div class="col-md-8">
                        <label class="form-label">Product</label>
                        <select name="Lines[@i].ProductId" class="form-select product-select">
                            <option value="">-- Select a product --</option>
                            @foreach (var p in Model.Products)
                            {
                                <option value="@p.Id"
                                        data-price="@p.Price"
                                        selected="@(Model.Lines[i].ProductId == p.Id)">
                                    @p.Name &mdash; @p.Price.ToString("C")
                                </option>
                            }
                        </select>
                    </div>
                    <div class="col-md-2">
                        <label class="form-label">Qty</label>
                        <input type="number" name="Lines[@i].Quantity"
                               value="@Model.Lines[i].Quantity"
                               min="1" max="100" class="form-control" />
                    </div>
                    <div class="col-md-2">
                        @if (i > 0)
                        {
                            <button type="button" class="btn btn-outline-danger w-100 remove-line">Remove</button>
                        }
                    </div>
                </div>
            }
        </div>
        <div class="card-footer">
            <button type="button" id="addLine" class="btn btn-outline-secondary btn-sm">+ Add Another Product</button>
        </div>
    </div>

    <div class="d-flex gap-2">
        <button type="submit" class="btn btn-success px-4">Place Order</button>
        <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
    </div>
</form>

<div class="mt-5 p-3 bg-light rounded small text-muted">
    <strong>What happens when you submit:</strong>
    <ol class="mb-0 mt-1">
        <li>MVC Frontend → <code>POST /api/orders</code> → API Gateway → OrderService</li>
        <li>OrderService saves the order to <code>OrderServiceDb</code></li>
        <li>OrderService publishes <code>OrderPlacedEvent</code> to RabbitMQ (async, non-blocking)</li>
        <li>Returns <code>201 Created</code> immediately</li>
        <li>NotificationService receives the event ~1 second later and logs <em>EMAIL SENT</em></li>
    </ol>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        // Dynamically add product lines (simple JS, no framework needed)
        let lineCount = @Model.Lines.Count;

        document.getElementById('addLine').addEventListener('click', function () {
            const container = document.querySelector('.card-body');
            const newLine = document.createElement('div');
            newLine.className = 'row g-2 mb-3 align-items-end order-line';
            newLine.innerHTML = `
                <div class="col-md-8">
                    <label class="form-label">Product</label>
                    <select name="Lines[${lineCount}].ProductId" class="form-select product-select">
                        <option value="">-- Select a product --</option>
                        @foreach (var p in Model.Products)
                        {
                            <option value="@p.Id" data-price="@p.Price">@p.Name &mdash; @p.Price.ToString("C")</option>
                        }
                    </select>
                </div>
                <div class="col-md-2">
                    <label class="form-label">Qty</label>
                    <input type="number" name="Lines[${lineCount}].Quantity" value="1" min="1" max="100" class="form-control" />
                </div>
                <div class="col-md-2">
                    <button type="button" class="btn btn-outline-danger w-100 remove-line">Remove</button>
                </div>`;
            container.appendChild(newLine);
            lineCount++;
        });

        document.addEventListener('click', function (e) {
            if (e.target.classList.contains('remove-line')) {
                e.target.closest('.order-line').remove();
            }
        });
    </script>
}
