# Copy this file to .env and fill in your values before running docker compose up

# SQL Server SA password — must meet SQL Server complexity requirements
SA_PASSWORD=YourStrong@Passw0rd

# JWT signing secret — must be at least 32 characters
JWT_SECRET=change-me-to-a-very-long-random-secret-at-least-32-chars!!

# RabbitMQ credentials
RABBITMQ_USER=guest
RABBITMQ_PASS=guest
